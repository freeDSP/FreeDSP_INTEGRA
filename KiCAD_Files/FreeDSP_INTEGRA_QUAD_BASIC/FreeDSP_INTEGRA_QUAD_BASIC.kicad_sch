	)
	(text "===== RCONSTRUCTION FILTER ALIGNMENTS=====\n\n[4.7uH + 0.33uF] for 6 ohms around\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 128kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.53 (4ohms Speaker)\n                     = 1.06 (8ohms Speaker)\n\n[4.7uH + 0.68uF] Best for 4 ohm speakers\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 89kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.76 (4ohms Speaker)\n                     = 1.5 (8ohms Speaker)\n\n[10uH + 1uF] another for 6 ohms around\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 61kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.63 (4ohm Speaker)\n                     = 1.26 (8 ohm Speaker)\n\n(15uH +0.33uF] another for 6 around\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 72kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.59 (4ohm Speaker)\n                     = 0.89 (6ohm Speaker)\n                     = 1.19 (8 ohm Speaker)\n\n(15uH +0.22uF] another for 6 ohms or more\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 88kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.72 (6ohm Speaker)\n                     = 0.96 (8ohm Speaker)\n                     = 1.92 (16 ohm Speaker)\n\n(15uH +0.1uF] for 8 ohms or more\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 130kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.65 (8ohm Speaker)\n                     = 1.3 (16 ohm Speaker)\n\n(22uH +0.22uF] for 8 ohms or more\nCutoff Frequency =1 / (2 * PI *  SQRT( L * C)) = 72kHz\nResonant Q = RL * SQRT(C /L) \n                     = 0.8 (8ohm Speaker)\n                     = 1.6 (16 ohm Speaker)"
		(exclude_from_sim no)
