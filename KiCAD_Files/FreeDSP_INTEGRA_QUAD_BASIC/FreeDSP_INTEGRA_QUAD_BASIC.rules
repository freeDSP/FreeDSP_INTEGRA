    "Net-(IC2-BOOT)" "Net-(U4-VI)" "Net-(D9-A)" "Net-(U3-SW)" "/YAM_DSP-ADC_IO/958RX" "Net-(U5-VO)" "DAT_IN0" "BCK_IN0"
