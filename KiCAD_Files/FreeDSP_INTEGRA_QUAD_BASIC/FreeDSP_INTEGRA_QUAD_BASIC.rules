
(rules PCB FreeDSP_INTEGRA_DUO
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout on)
    (autoroute on)
    (postroute on)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 105678)
    (layer_rule F.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.6)
      (against_preferred_direction_trace_costs 3.1)
    )
    (layer_rule In1.Cu
      (active off)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 2.5)
    )
    (layer_rule In2.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 1.7)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.6)
      (against_preferred_direction_trace_costs 3.1)
    )
  )
  (rule
    (width 250.0)
    (clear 150.0)
    (clear 125.0 (type smd_to_turn_gap))
    (clear 37.6 (type smd_smd))
  )
  (padstack "Via[0-3]_800:400_um"
    (shape
      (circle F.Cu 800.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 800.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 800.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 800.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-3]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-3]_1000:700_um"
    (shape
      (circle F.Cu 1000.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 1000.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 1000.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 1000.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-3]_1600:1000_um"
    (shape
      (circle F.Cu 1600.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 1600.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 1600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 1600.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-3]_700:400_um"
    (shape
      (circle F.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 700.0 0.0 0.0)
    )
    (attach off)
  )
  (padstack "Via[0-3]_700:300_um"
    (shape
      (circle F.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 700.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 700.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-3]_800:400_um" "Via[0-3]_800:400_um" default
  )
  (via 
    "Via[0-3]_600:300_um" "Via[0-3]_600:300_um" default
  )
  (via 
    "Via[0-3]_1000:700_um" "Via[0-3]_1000:700_um" default
  )
  (via 
    "Via[0-3]_1600:1000_um" "Via[0-3]_1600:1000_um" default
  )
  (via 
    "Via[0-3]_700:300_um" "Via[0-3]_700:300_um" default
  )
  (via 
    "Via[0-3]_700:400_um" "Via[0-3]_700:400_um" default
  )
  (via 
    "Via[0-3]_800:400_um-kicad_default" "Via[0-3]_800:400_um" "kicad_default"
  )
  (via 
    "Via[0-3]_600:300_um-kicad_default" "Via[0-3]_600:300_um" "kicad_default"
  )
  (via 
    "Via[0-3]_1000:700_um-kicad_default" "Via[0-3]_1000:700_um" "kicad_default"
  )
  (via 
    "Via[0-3]_1600:1000_um-kicad_default" "Via[0-3]_1600:1000_um" "kicad_default"
  )
  (via 
    "Via[0-3]_700:300_um-kicad_default" "Via[0-3]_700:300_um" "kicad_default"
  )
  (via 
    "Via[0-3]_700:400_um-kicad_default" "Via[0-3]_700:400_um" "kicad_default"
  )
  (via 
    "Via[0-3]_800:400_um-TAS-PINS" "Via[0-3]_800:400_um" "TAS-PINS"
  )
  (via 
    "Via[0-3]_600:300_um-TAS-PINS" "Via[0-3]_600:300_um" "TAS-PINS"
  )
  (via 
    "Via[0-3]_1000:700_um-TAS-PINS" "Via[0-3]_1000:700_um" "TAS-PINS"
  )
  (via 
    "Via[0-3]_1600:1000_um-TAS-PINS" "Via[0-3]_1600:1000_um" "TAS-PINS"
  )
  (via 
    "Via[0-3]_700:300_um-TAS-PINS" "Via[0-3]_700:300_um" "TAS-PINS"
  )
  (via 
    "Via[0-3]_700:400_um-TAS-PINS" "Via[0-3]_700:400_um" "TAS-PINS"
  )
  (via_rule
    default "Via[0-3]_600:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-3]_800:400_um-kicad_default"
  )
  (via_rule
    "TAS-PINS" "Via[0-3]_800:400_um-TAS-PINS"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 250.0)
    )
    (layer_rule In1.Cu
      (rule 
        (width 0.0) 
      )
    )
    (circuit 
      (use_layer F.Cu In2.Cu B.Cu)
    )
  )
  (class "kicad_default"
